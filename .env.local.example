# Slack bot token(xoxb-...);複製成 .env.local 再填真值,勿提交真實值。
SLACK_BOT_TOKEN=
# 目標頻道 ID(#cry)
SLACK_CHANNEL_ID=C0BEBHYB56E

# ── 紙上交易(paper trading)─────────────────────────────
# 每輪掃描自動把推播出去的新機會記帳、依後續 K 線結算,週一自動推成績單。
PAPER_START_EQUITY=2000       # 起始權益(USDT)
# PAPER_LEDGER_PATH=./data/paper-ledger.json  # 帳本路徑(預設)
# PAPER_ENABLED=0             # 設 0 可關閉記帳
